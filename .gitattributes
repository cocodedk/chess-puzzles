# Normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly declare common text files
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.toml      text eol=lf
*.pro       text eol=lf
*.properties text eol=lf
gradlew     text eol=lf

# Windows scripts keep CRLF
*.bat       text eol=crlf

# Binary files — never diff or convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.apk       binary
*.jar       binary
*.keystore  binary
*.jks       binary
*.zip       binary
*.tar.gz    binary
*.zst       binary
