#!/bin/sh
set -eu

# Fast static checks ONLY. The full test suite + 100% coverage gate run at pre-push,
# not on every commit, so the commit loop stays fast (CLAUDE.md three-tier gate).
[ -f "$HOME/.chess-env.sh" ] && . "$HOME/.chess-env.sh"
echo "pre-commit: running fast lint (./gradlew lintDebug)..."
./gradlew lintDebug --quiet </dev/null
