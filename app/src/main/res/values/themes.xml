<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Post-splash application theme (the window behind the Compose UI). -->
    <style name="Theme.ChessPuzzles" parent="@android:style/Theme.Material.Light.NoActionBar" />

    <!-- Launch theme: branded splash via androidx.core:core-splashscreen. -->
    <style name="Theme.ChessPuzzles.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ChessPuzzles</item>
    </style>
</resources>
